<!DOCTYPE html>
<html lang="es" data-bs-theme="dark">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>SimpleDashboard</title>
  <!-- Bootstrap 5.3 CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">  <!-- Favicon Emoji -->
  <link rel="icon"
    href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>⚜️</text></svg>">
  <style>
    body {
      background-image: url('<%= backgroundUrl %>') !important;
      background-size: cover;
      background-position: center;
      background-attachment: fixed;
      min-height: 100vh;
    }

    .glass-card {
      background: rgba(26, 26, 26, 0.3);
      backdrop-filter: blur(10px);
      border: 1px solid rgba(255, 255, 255, 0.1);
      transition: transform 0.2s;
    }

    .glass-card:hover {
      transform: translateY(-5px);
      background: rgba(40, 40, 40, 0.75);
    }

    .icon-img {
      width: 64px;
      height: 64px;
      object-fit: contain;
    }
  </style>
</head>

<body>
  <nav class="navbar navbar-expand-lg navbar-dark bg-dark bg-opacity-75 shadow-sm mb-4">
    <div class="container">
      <a class="navbar-brand" href="/">⚜️ SimpleDashboard</a>
      <div class="navbar-nav ms-auto">
        <a class="nav-link" href="/edit">🛠️ Ajustes</a>
      </div>
    </div>
  </nav>

  <div class="container">
    <div class="row row-cols-1 row-cols-sm-2 row-cols-md-5 row-cols-lg-6 g-4">
      <% items.forEach(item=> { %>
        <div class="col">
          <a href="<%= item.url %>" target="_blank" class="text-decoration-none">
            <div class="card h-100 glass-card shadow-sm text-white">
              <div class="card-body text-center d-flex flex-column align-items-center justify-content-center">
                <% if(item.icon) { %>
                  <img src="/icons/<%= item.icon %>" class="icon-img mb-3" alt="<%= item.title %>">
                  <% } else { %>
                    <div class="icon-img mb-3 d-flex align-items-center justify-content-center bg-secondary rounded">
                      <span>📦</span>
                    </div>
                    <% } %>
                      <h5 class="card-title mb-1 text-truncate w-100">
                        <%= item.title %>
                      </h5>
              </div>
            </div>
          </a>
        </div>
        <% }); %>
    </div>
  </div>

  <!-- Bootstrap 5.3 JS -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>